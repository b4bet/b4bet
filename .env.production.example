# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
#
# Use this template when deploying to production (Vercel, AWS, etc.)
# All sensitive values MUST be added via the deployment platform's UI
# 
# DO NOT commit actual values to git!
# DO NOT create a .env.production file with real secrets!
#
# Instead, add these variables using:
# - Vercel Dashboard: Settings > Environment Variables
# - AWS: Systems Manager > Parameter Store
# - Heroku: Settings > Config Vars
# - Your platform's env var management system
#
# ============================================================================

# ============================================================================
# PRODUCTION SUPABASE
# ============================================================================
# Add these via your platform's environment variables UI

# Production Supabase URL (get from: https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co

# Production Anon Key (public, safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_PRODUCTION_ANON_KEY

# Production Service Role Key (PRIVATE - add via UI only!)
# Never hardcode this! Use environment variable management system.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_PRODUCTION_SERVICE_ROLE_KEY

# Production JWT Secret (PRIVATE - add via UI only!)
SUPABASE_JWT_SECRET=your-production-jwt-secret-min-32-chars-required

# ============================================================================
# PRODUCTION DATABASE
# ============================================================================

# Use Supabase connection string (recommended)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@your-production-project.supabase.co:5432/postgres

# Or use individual variables:
DATABASE_HOST=your-production-project.supabase.co
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=YOUR_SECURE_PASSWORD

# ============================================================================
# PRODUCTION APPLICATION SETTINGS
# ============================================================================

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Production Edge Functions URL
NEXT_PUBLIC_SUPABASE_FUNCTIONS_URL=https://your-production-project.supabase.co/functions/v1

# ============================================================================
# PRODUCTION SECURITY SETTINGS
# ============================================================================
# IMPORTANT: These should be restrictive in production!

DEBUG_MODE=false

# Strict rate limiting in production
API_RATE_LIMIT=60

# Realistic bet limits
MAX_BET_AMOUNT=1000000
MIN_BET_AMOUNT=100
MAX_BALANCE=10000000

# Shorter session timeout for security
SESSION_TIMEOUT=30

# ============================================================================
# PRODUCTION MONITORING (RECOMMENDED)
# ============================================================================

# Sentry for error tracking (optional but recommended)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456

# PostHog for analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-api-key

# ============================================================================
# PRODUCTION PAYMENT PROCESSING (IF APPLICABLE)
# ============================================================================

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# ============================================================================
# PRODUCTION VERCEL CONFIGURATION
# ============================================================================

# If deploying to Vercel, add these via Vercel Dashboard

VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_ORG_ID=your-vercel-org-id

# ============================================================================
# HOW TO DEPLOY TO VERCEL WITH ENVIRONMENT VARIABLES
# ============================================================================
#
# Step 1: Connect your GitHub repository to Vercel
#   - Go to: https://vercel.com/new
#   - Connect your Git provider
#   - Select your repository
#
# Step 2: Add Environment Variables in Vercel Dashboard
#   - Go to: https://vercel.com/dashboard
#   - Select your project
#   - Settings > Environment Variables
#   - Click "Add New"
#   - Add each variable from this file
#   - Set Environment to: Production / Preview / Development as needed
#
# Step 3: Environment Variable Format
#   Name: NEXT_PUBLIC_SUPABASE_URL
#   Value: https://your-project.supabase.co
#   Environments: Select all (Production, Preview, Development)
#
# Step 4: Sensitive Variables (IMPORTANT!)
#   - SUPABASE_SERVICE_ROLE_KEY → Add only to Production
#   - STRIPE_SECRET_KEY → Add only to Production
#   - Add with minimal access for security
#
# Step 5: Deploy
#   - Push to main branch (or your deploy branch)
#   - Vercel automatically deploys
#   - Variables are available to build and runtime
#
# ============================================================================
# HOW TO SET SECRETS IN SUPABASE EDGE FUNCTIONS
# ============================================================================
#
# Step 1: Install Supabase CLI
#   brew install supabase/tap/supabase
#
# Step 2: Log in to Supabase
#   supabase login
#
# Step 3: Link your project
#   supabase link --project-ref your-project-ref
#
# Step 4: Set secrets for Edge Functions
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
#   supabase secrets set SUPABASE_JWT_SECRET="your-jwt-secret"
#
# Step 5: Deploy functions with secrets
#   supabase functions deploy process-bet
#   supabase functions deploy get-balance
#   supabase functions deploy get-stats
#
# Step 6: Verify secrets are set
#   supabase secrets list
#
# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
#
# Before deploying to production:
#
# [ ] All environment variables added to Vercel Dashboard
# [ ] SUPABASE_SERVICE_ROLE_KEY set to Production environment only
# [ ] STRIPE_SECRET_KEY set to Production environment only
# [ ] DATABASE_URL correctly configured
# [ ] NEXT_PUBLIC_APP_URL points to your production domain
# [ ] DEBUG_MODE set to false
# [ ] API rate limits configured (API_RATE_LIMIT=60)
# [ ] SSL/HTTPS enforced
# [ ] Supabase RLS policies enabled and tested
# [ ] Edge Functions deployed and secrets set
# [ ] Database backups configured
# [ ] Monitoring and alerting set up (Sentry, PostHog, etc.)
# [ ] Security audit checklist completed (SECURITY_AUDIT_CHECKLIST.md)
# [ ] Load testing completed
# [ ] Incident response plan documented
# [ ] Team briefed on security architecture
#
# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# 1. NEVER hardcode secrets in .env files
# 2. NEVER commit .env files to git
# 3. ALWAYS use your platform's secret management (Vercel, AWS, etc.)
# 4. ALWAYS use HTTPS in production
# 5. ALWAYS rotate secrets periodically (at least annually)
# 6. ALWAYS audit environment variables regularly
# 7. ALWAYS enable Supabase RLS policies
# 8. ALWAYS validate all inputs server-side
# 9. ALWAYS log security events
# 10. ALWAYS monitor for unusual activity
#
# ============================================================================
