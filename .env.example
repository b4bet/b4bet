# ============================================================================
# IRON-CLAD SECURITY OVERHAUL - ENVIRONMENT VARIABLES
# ============================================================================
# 
# This file shows ALL environment variables needed for the secure setup.
# Copy this to .env.local and fill in your actual values.
#
# NEVER commit .env.local to git - it contains secrets!
# ============================================================================

# ============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# ============================================================================
# Get these from: https://app.supabase.com/project/_/settings/api

# Your Supabase project URL (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase public anon key (public - safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (PRIVATE - NEVER expose this!)
# Only used server-side and in Edge Functions
# Get from: https://app.supabase.com/project/_/settings/api -> Service Role Key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase JWT Secret (for signing tokens)
# Get from: https://app.supabase.com/project/_/settings/api -> JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-key-here

# ============================================================================
# EDGE FUNCTION SECRETS
# ============================================================================
# These are used by Supabase Edge Functions for enhanced security

# Service role key (used for authenticated operations)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Function timeout (milliseconds) - for long-running operations
FUNCTION_TIMEOUT=30000

# ============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================================================
# PostgreSQL connection string (if using direct connection)

# Database host
DATABASE_HOST=your-project.supabase.co

# Database port (default PostgreSQL)
DATABASE_PORT=5432

# Database name (default is 'postgres')
DATABASE_NAME=postgres

# Database user
DATABASE_USER=postgres

# Database password
DATABASE_PASSWORD=your-secure-password

# Full connection string (alternative to separate vars)
DATABASE_URL=postgresql://postgres:password@your-project.supabase.co:5432/postgres

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# API Rate Limiting (requests per minute per user)
API_RATE_LIMIT=100

# Maximum bet amount (in cents)
MAX_BET_AMOUNT=1000000

# Minimum bet amount (in cents)
MIN_BET_AMOUNT=100

# Maximum balance (in cents)
MAX_BALANCE=10000000

# Session timeout (minutes)
SESSION_TIMEOUT=60

# Enable detailed logging (true/false)
DEBUG_MODE=false

# ============================================================================
# NEXT.JS / APPLICATION SETTINGS
# ============================================================================

# Environment (development, staging, production)
NODE_ENV=development

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API endpoint for Supabase functions
NEXT_PUBLIC_SUPABASE_FUNCTIONS_URL=http://localhost:3000/functions/v1

# ============================================================================
# MONITORING & LOGGING (OPTIONAL)
# ============================================================================

# Sentry DSN for error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=

# PostHog API key for analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=

# Datadog API key (optional)
DATADOG_API_KEY=

# ============================================================================
# STRIPE INTEGRATION (IF USING PAYMENTS)
# ============================================================================
# Optional - only if you're integrating payment processing

# Stripe public key (can be public)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe secret key (PRIVATE - server only)
STRIPE_SECRET_KEY=sk_live_...

# ============================================================================
# AUTH SETTINGS
# ============================================================================

# JWT expiration (hours)
JWT_EXPIRATION=24

# Refresh token expiration (days)
REFRESH_TOKEN_EXPIRATION=30

# Enable password reset emails
ENABLE_PASSWORD_RESET=true

# Email sender address
EMAIL_FROM=noreply@yourapp.com

# ============================================================================
# EDGE FUNCTION DEPLOYMENT
# ============================================================================
# Used by Supabase CLI when deploying functions

# Supabase project reference
SUPABASE_PROJECT_REF=your-project-ref

# Supabase project ID
SUPABASE_PROJECT_ID=your-project-id

# ============================================================================
# DEPLOYMENT PLATFORMS
# ============================================================================

# Vercel (if deploying to Vercel)
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_TOKEN=your-vercel-token

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable maintenance mode
MAINTENANCE_MODE=false

# Enable new game types (before full release)
BETA_FEATURES_ENABLED=false

# ============================================================================
# HELP & DOCUMENTATION
# ============================================================================
#
# 1. Get Supabase credentials:
#    - Go to: https://app.supabase.com/project/_/settings/api
#    - Copy URL and Anon Key (public)
#    - Copy Service Role Key (private)
#    - Copy JWT Secret
#
# 2. Set up local .env.local:
#    cp .env.example .env.local
#    # Edit .env.local with your actual values
#
# 3. For development:
#    npm install
#    npm run dev
#
# 4. For production:
#    - Add all variables to Vercel: vercel env add
#    - Or use Vercel UI: Settings > Environment Variables
#    - Deploy: git push (or use vercel deploy)
#
# 5. For Edge Functions:
#    - Install Supabase CLI: brew install supabase/tap/supabase
#    - Deploy: supabase functions deploy
#    - Set secrets: supabase secrets set KEY=VALUE
#
# ============================================================================
