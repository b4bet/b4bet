# ============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT
# ============================================================================
# 
# Copy this file to .env.local and fill in your local Supabase credentials
# This file should NEVER be committed to git
#
# .env.local is gitignored and only loaded during local development
# ============================================================================

# ============================================================================
# LOCAL SUPABASE SETUP
# ============================================================================

# For local development with Supabase (using Docker)
# Get these from your local Supabase setup

NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxvY2FsIiwicm9sZSI6ImFub24iLCJpYXQiOjE2MDAwMDAwMDAsImV4cCI6MjAwMDAwMDAwfQ.PLACEHOLDER_LOCAL_KEY

# Service role key for local development (NEVER push to production!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxvY2FsIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTYwMDAwMDAwMCwiZXhwIjoyMDAwMDAwMDB9.PLACEHOLDER_LOCAL_SERVICE_KEY

# Local JWT secret
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# ============================================================================
# LOCAL DATABASE
# ============================================================================

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Local database connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ============================================================================
# LOCAL APPLICATION SETTINGS
# ============================================================================

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_FUNCTIONS_URL=http://localhost:3000/functions/v1

# ============================================================================
# LOCAL SECURITY SETTINGS
# ============================================================================

DEBUG_MODE=true
API_RATE_LIMIT=1000
MAX_BET_AMOUNT=1000000
MIN_BET_AMOUNT=100
MAX_BALANCE=10000000
SESSION_TIMEOUT=60

# ============================================================================
# LOCAL OPTIONAL SERVICES
# ============================================================================

# Sentry (leave blank for local development)
NEXT_PUBLIC_SENTRY_DSN=

# PostHog (leave blank for local development)
NEXT_PUBLIC_POSTHOG_KEY=

# ============================================================================
# SETUP INSTRUCTIONS FOR LOCAL DEVELOPMENT
# ============================================================================
#
# 1. Start Supabase locally (if using local instance):
#    supabase start
#
# 2. Get your local credentials:
#    supabase status
#    # This will show your local SUPABASE_URL and ANON_KEY
#
# 3. Update this file (.env.local) with the values from step 2
#
# 4. Load the database schema:
#    supabase db push
#    # This applies all migrations and creates tables
#
# 5. Set up Edge Functions locally:
#    supabase functions serve
#    # In another terminal
#
# 6. Start the development server:
#    npm run dev
#    # App will be at http://localhost:3000
#
# 7. Test the security:
#    Open http://localhost:3000
#    Try placing a bet - it should call the Edge Function
#    Check browser console - no Math.random() calls!
#
# ============================================================================
